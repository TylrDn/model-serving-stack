{
  "title": "LLM Serving Stack",
  "panels": [
    {
      "title": "GPU Utilization",
      "type": "graph",
      "targets": [{"expr": "DCGM_FI_DEV_GPU_UTIL"}]
    },
    {
      "title": "Request Throughput (req/s)",
      "type": "graph",
      "targets": [{"expr": "rate(vllm_requests_total[1m])"}]
    },
    {
      "title": "P99 Latency (ms)",
      "type": "graph",
      "targets": [{"expr": "histogram_quantile(0.99, vllm_request_duration_seconds_bucket)"}]
    },
    {
      "title": "Active Replicas",
      "type": "stat",
      "targets": [{"expr": "kube_deployment_status_replicas{deployment='vllm-server'}"}]
    }
  ]
}
