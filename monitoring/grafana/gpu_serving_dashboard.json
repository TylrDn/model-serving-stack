{
  "title": "GPU LLM Serving Dashboard",
  "uid": "gpu-llm-serving",
  "schemaVersion": 38,
  "version": 1,
  "panels": [
    {
      "id": 1,
      "title": "GPU Utilization %",
      "type": "timeseries",
      "targets": [
        {
          "expr": "DCGM_FI_DEV_GPU_UTIL",
          "legendFormat": "GPU {{gpu}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100}}
    },
    {
      "id": 2,
      "title": "GPU Memory Used (MiB)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "DCGM_FI_DEV_FB_USED",
          "legendFormat": "GPU {{gpu}} Memory"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "decmbytes"}}
    },
    {
      "id": 3,
      "title": "vLLM Tokens/sec Throughput",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(vllm:generation_tokens_total[1m])",
          "legendFormat": "Tokens/sec"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "id": 4,
      "title": "vLLM Request Queue Depth",
      "type": "stat",
      "targets": [
        {
          "expr": "vllm:num_requests_waiting",
          "legendFormat": "Waiting"
        }
      ]
    },
    {
      "id": 5,
      "title": "GPU Power (W)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "DCGM_FI_DEV_POWER_USAGE",
          "legendFormat": "GPU {{gpu}} Power"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "watt"}}
    }
  ],
  "time": {"from": "now-1h", "to": "now"},
  "refresh": "10s"
}
