  ingress.yaml

monitoring/
  grafana/
    gpu_serving_dashboard.json  ← CANONICAL Grafana dashboard
  prometheus/
    prometheus.yml
  # grafana_dashboard.json ROOT DUPLICATE — must be removed

autoscaling/
  hpa.yaml

deploy/
  Dockerfile
  docker-compose.yml

configs/
  models.yaml
  serving.yaml

evals/
  benchmark.py

tests/

docker-compose.yml      ← ROOT (confirmed present)
```

